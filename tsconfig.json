{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "react",
      "react-native"
    ]
  },
  "include": [
    "App.tsx",
    "src"
  ]
}
